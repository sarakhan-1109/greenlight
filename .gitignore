# ---- Python / backend ----
backend/.venv/
__pycache__/
*.pyc
.env
*.env

# ---- Node / frontend ----
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ---- Raw/intermediate data (large / regenerable) ----
model/data/*.csv
model/data/*.zip
model/data/*.json

# NOTE: backend/artifacts/ (trained model + metadata) is INTENTIONALLY committed
# so the Render backend can serve the model. Those files are small and required
# at runtime, so they are not ignored.

