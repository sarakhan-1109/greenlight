# Copy to `backend/.env` for local development.

# Comma-separated list of allowed frontend origins (CORS). Use * in dev.
ALLOWED_ORIGINS=*

# Google Gemini API key — used only by the LLM interpretation layer.
# Free key from https://aistudio.google.com/apikey (no credit card needed).
# Leave blank and the app falls back to a deterministic template note.
GEMINI_API_KEY=
